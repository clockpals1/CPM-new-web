# CelestialPeopleMeeet — Backend Environment Variables
# Copy this to .env and fill in your values (never commit .env)

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name
DB_NAME=celestialpeoplemeet

# JWT secret — use a long random string (min 32 chars)
JWT_SECRET=replace-with-a-very-long-random-secret-string

# Super admin seed credentials (created on first startup)
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=YourStrongPassword@2026
ADMIN_NAME=Super Admin

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://celestialpeoplemeet.com,https://www.celestialpeoplemeet.com,http://localhost:3000
