# CelestialPeopleMeeet — Frontend Environment Variables
# Copy this to .env and fill in your values (never commit .env)
# In Cloudflare Pages, set these under Settings → Environment Variables

# URL of the backend API (no trailing slash)
# Local development: http://localhost:8001
# Production (Render): https://cpm-backend.onrender.com
REACT_APP_BACKEND_URL=https://cpm-backend.onrender.com
